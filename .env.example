# 재고 알림 메일 발송용 설정
# 로컬: 이 파일을 .env 로 복사한 뒤 값을 채워 사용하세요.
# Vercel: Settings → Environment Variables 에 아래와 동일한 이름으로 설정 (INVENTORY_SENDER_PASSWORD 필수).

# 발신 이메일 (기본: byw004422@gmail.com)
INVENTORY_SENDER_EMAIL=byw004422@gmail.com

# Gmail 앱 비밀번호 (Vercel 환경 변수에도 동일 이름 INVENTORY_SENDER_PASSWORD 로 설정)
INVENTORY_SENDER_PASSWORD=your_app_password_here

# 담당자 이메일(수신)은 환경 변수가 아니라 웹 페이지 상단 입력란에서 입력합니다.

# 엑셀 파일 경로 (선택, 기본: 이 폴더의 domino_inventory_training.xlsx)
# INVENTORY_EXCEL_PATH=c:\path\to\domino_inventory_training.xlsx
